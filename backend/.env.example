# Attendance & Payroll System - Environment Variables
# Copy this file to .env and fill in the values

# ===================
# REQUIRED IN PRODUCTION
# ===================

# Secret key for JWT tokens (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# Environment: development, staging, production
ENVIRONMENT=development

# ===================
# DATABASE
# ===================

# SQLite (default for development)
DATABASE_URL=sqlite:///./attendance_payroll.db

# MySQL example (for production)
# DATABASE_URL=mysql://user:password@localhost:3306/attendance_payroll

# ===================
# SECURITY SETTINGS
# ===================

# CORS origins (comma-separated, or "*" for all - use "*" for local network)
CORS_ORIGINS=*

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRY_DAYS=90

# ===================
# EMAIL (Optional)
# ===================

# Gmail SMTP settings
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=ICAN A&P System

# ===================
# OPTIONAL SETTINGS
# ===================

# Debug mode (disable in production)
DEBUG=true

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=2555
