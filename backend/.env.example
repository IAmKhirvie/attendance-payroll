# Attendance & Payroll System - Environment Variables
# Copy this file to .env and fill in the values
#
# SECURITY WARNING: Never commit .env to version control!
# SECURITY WARNING: Use strong, unique values for all secrets!

# ===================
# REQUIRED IN PRODUCTION
# ===================

# Secret key for JWT tokens
# SECURITY: Generate a strong key with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# SECURITY: Must be at least 32 characters, ideally 64+
# SECURITY: Never reuse keys across environments
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_64

# Environment: development, staging, production
# SECURITY: Set to "production" in live environments to enable strict security checks
ENVIRONMENT=development

# ===================
# DATABASE
# ===================

# SQLite (default for development only)
DATABASE_URL=sqlite:///./attendance_payroll.db

# MySQL example (recommended for production)
# SECURITY: Use strong passwords and limit database user permissions
# DATABASE_URL=mysql://user:password@localhost:3306/attendance_payroll

# PostgreSQL example (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/attendance_payroll

# ===================
# SECURITY SETTINGS
# ===================

# CORS origins (comma-separated list of allowed origins)
# SECURITY: In production, specify exact domains - never use "*"
# SECURITY: For local network access during development only: CORS_ORIGINS=*
# Production example: CORS_ORIGINS=https://app.yourcompany.com,https://admin.yourcompany.com
CORS_ORIGINS=http://localhost:4500,http://localhost:5173

# Allow credentials with CORS (required for cookies)
CORS_ALLOW_CREDENTIALS=true

# Password policy
# SECURITY: Keep these strict in production
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRY_DAYS=90

# Rate limiting
# SECURITY: Adjust based on expected traffic
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_MAX_REQUESTS=240
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
RATE_LIMIT_IMPORT_MAX_REQUESTS=20
RATE_LIMIT_IMPORT_WINDOW_SECONDS=60

# ===================
# EMAIL (Optional)
# ===================

# SECURITY: Use app-specific passwords, never your main password
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=ICAN A&P System

# ===================
# OPTIONAL SETTINGS
# ===================

# Debug mode
# SECURITY: Always set to false in production!
# SECURITY: Debug mode exposes stack traces and sensitive information
DEBUG=false

# App log directory, relative to backend/app/main.py unless absolute
LOG_DIR=../logs

# Token expiration
# SECURITY: Shorter expiration = more secure but less convenient
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Audit log retention (days) - default 7 years for compliance
AUDIT_LOG_RETENTION_DAYS=2555

# ===================
# SSL/HTTPS (Production)
# ===================

# SECURITY: Always use HTTPS in production
# SSL_KEYFILE=/path/to/privkey.pem
# SSL_CERTFILE=/path/to/fullchain.pem

# Enable HSTS (HTTP Strict Transport Security)
# SECURITY: Only enable after confirming HTTPS works properly
ENABLE_HSTS=false
